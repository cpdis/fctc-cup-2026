{
  "name": "fctc-cup",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "FCTC Cup race-replay visualisation",
  "scripts": {
    "dev": "vite",
    "bake": "tsx scripts/bake-data.ts",
