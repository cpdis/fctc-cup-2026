{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/cup", "destination": "/index.html" },
    { "source": "/cup/", "destination": "/index.html" },
    { "source": "/cup/:path+", "destination": "/:path+" }
  ],
  "headers": [
    {
      "source": "/(cup/)?basemap.pmtiles",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, HEAD" },
        { "key": "Access-Control-Allow-Headers", "value": "Range" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Range, Content-Length, ETag" }
      ]
    },
    {
      "source": "/(cup/)?replay.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    }
  ]
}
